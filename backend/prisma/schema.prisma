generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  DEVELOPER
}

enum AccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum PaymentProvider {
  STRIPE
  SOLANA
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum AiRequestStatus {
  CREATED
  RUNNING
  COMPLETED
  FAILED
  PLACEHOLDER
}

model User {
  id                             String        @id @default(cuid())
  email                          String        @unique
  passwordHash                   String
  name                           String?
  avatarUrl                      String?
  role                           UserRole      @default(USER)
  status                         AccountStatus @default(ACTIVE)
  credits                        Int           @default(0)
  emailVerifiedAt                DateTime?
  activationTokenHash            String?       @unique
  activationTokenExpiresAt       DateTime?
  resetPasswordTokenHash         String?       @unique
  resetPasswordTokenExpiresAt    DateTime?
  lastLoginAt                    DateTime?
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt

  requests                       AiRequest[]
  payments                       Payment[]

  @@index([email])
  @@index([status])
}

model Payment {
  id              String          @id @default(cuid())
  userId          String?
  user            User?           @relation(fields: [userId], references: [id])
  provider        PaymentProvider
  status          PaymentStatus   @default(PENDING)
  amountCents     Int
  currency        String
  credits         Int             @default(0)
  description     String?
  externalId      String?         @unique
  solanaSignature String?         @unique
  solanaReceiver  String?
  raw             Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model AiRequest {
  id        String          @id @default(cuid())
  userId    String?
  user      User?           @relation(fields: [userId], references: [id])
  service   String
  model     String?
  prompt    String?
  status    AiRequestStatus @default(CREATED)
  result    Json?
  error     String?
  cost      Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}
