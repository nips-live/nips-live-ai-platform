NODE_ENV=production
PORT=4000
PUBLIC_URL=https://api.nips.live
FRONTEND_URL=https://nips.live
CORS_ORIGINS=https://nips.live,https://www.nips.live
DATABASE_URL=postgresql://nips_user:CHANGE_THIS_PASSWORD@postgres:5432/nips_live?schema=public
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

ADMIN_EMAIL=admin@nips.live
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
DEFAULT_FREE_CREDITS=25
PLATFORM_FEE_BPS=335

# Set true if you want users to activate by email link before login.
# Set false if you want instant login after registration.
REQUIRE_EMAIL_ACTIVATION=false
ACTIVATION_TOKEN_MINUTES=1440
RESET_PASSWORD_TOKEN_MINUTES=60

# Optional SMTP. If not set, activation/reset links are returned in JSON for setup/testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=NIPS.live <no-reply@nips.live>

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://nips.live/account/billing/success
STRIPE_CANCEL_URL=https://nips.live/account/billing/cancel
SOLANA_TREASURY_WALLET=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
